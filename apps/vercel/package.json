{
  "name": "@original/blog-vercel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sync:content-media": "node ../../scripts/sync-content-media.mjs vercel",
    "generate:version": "node ../../scripts/generate-build-version.mjs vercel",
    "dev": "pnpm sync:content-media && pnpm generate:version && next dev --webpack",
    "build": "pnpm sync:content-media && pnpm generate:version && next build",
    "serve": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@original/content": "workspace:*",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "24.10.1",
    "@types/react": "19.2.6",
    "@vercel/analytics": "1.5.0",
    "@vercel/speed-insights": "^1.0.2",
    "classnames": "2.5.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "gsap": "3.13.0",
    "katex": "^0.16.28",
    "lenis": "^1.2.3",
    "motion": "12.23.24",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "0.4.6",
    "postcss": "8.5.16",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "0.14.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "3.15.0",
    "tailwindcss": "^4.0.15",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "babel-plugin-react-compiler": "^1.0.0"
  }
}
