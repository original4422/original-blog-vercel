{
  "name": "original-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev:vercel": "pnpm --filter @original/blog-vercel dev",
    "dev:pages": "pnpm --filter @original/blog-pages dev",
    "build": "pnpm -r --if-present build",
    "build:vercel": "pnpm --filter @original/blog-vercel build",
    "build:pages": "pnpm --filter @original/blog-pages build",
    "preview:pages": "pnpm --filter @original/blog-pages preview",
    "audit:content": "tsx scripts/audit-content.ts",
    "audit:versions": "node scripts/audit-build-versions.mjs",
    "check": "pnpm -r --if-present check",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.16",
      "yaml": "2.9.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "tsx": "^4.23.1"
  }
}
