{
  "name": "@original/blog-pages",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sync:content-media": "node ../../scripts/sync-content-media.mjs pages",
    "generate:version": "node ../../scripts/generate-build-version.mjs pages",
    "dev": "pnpm sync:content-media && pnpm generate:version && next dev --webpack",
    "generate": "tsx scripts/generate-static.mjs",
    "build": "pnpm sync:content-media && pnpm generate:version && pnpm generate && next build",
    "preview": "node ../../scripts/preview-pages.mjs",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "audit:static": "node scripts/audit-static.mjs"
  },
  "dependencies": {
    "@original/content": "workspace:*",
    "@tailwindcss/postcss": "^4.1.11",
    "classnames": "^2.5.1",
    "fuse.js": "^7.1.0",
    "gsap": "^3.13.0",
    "katex": "^0.16.28",
    "lenis": "^1.3.15",
    "lucide-react": "^0.525.0",
    "motion": "^12.23.24",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.15.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
